# ──────────────────────────────────────────────
# Supabase — get from https://supabase.com/dashboard → Project Settings → API
# ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ──────────────────────────────────────────────
# Xero OAuth 2.0 — https://developer.xero.com/app/manage
# ──────────────────────────────────────────────
XERO_CLIENT_ID=your-xero-client-id
XERO_CLIENT_SECRET=your-xero-client-secret
XERO_WEBHOOK_KEY=your-xero-webhook-signing-key
XERO_REDIRECT_URI=http://localhost:4000/auth/xero/callback

# ──────────────────────────────────────────────
# Resend — https://resend.com/api-keys
# ──────────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=invoices@adconfirm.io

# ──────────────────────────────────────────────
# Public env vars (safe to expose in browser bundles)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:4000
